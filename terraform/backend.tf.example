# =============================================================================
# Terraform Backend — AWS S3 with native state locking
# =============================================================================
# Copy this file to backend.tf to enable remote state. Values are populated at
# init time via `-backend-config` flags from the GitLab pipeline (see the
# `.terraform-init` snippet in ../.gitlab-ci.yml), so you should NOT hard-code
# the bucket name, key, or region here.
#
# Locking
#   Uses S3 native state locking (Terraform >= 1.10, AWS provider >= 5.85).
#   The lock lives as a small `<key>.tflock` object in the same bucket via S3
#   conditional writes — no DynamoDB table required.
#
# Authentication
#   The runner's EC2 instance role provides credentials automatically via
#   IMDS. No AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY required.
#
# Example (run locally to migrate existing state once):
#   cp backend.tf.example backend.tf
#   terraform init \
#     -backend-config="bucket=elastic-dac-terraform" \
#     -backend-config="key=t/elastic-dac/terraform.tfstate" \
#     -backend-config="region=us-east-1" \
#     -backend-config="use_lockfile=true" \
#     -backend-config="encrypt=true" \
#     -migrate-state
#
# IMPORTANT — prefix restriction
#   The runner's IAM role is scoped to s3://<bucket>/t/* only. The state
#   key MUST therefore start with `t/` (e.g. t/elastic-dac/terraform.tfstate).
#   The .gitlab-ci.yml `.terraform-init` snippet enforces this and fails
#   fast with a clear message if TF_STATE_KEY does not match.
#
# Bucket provisioning is documented in:
#   ../.gitlab/GITLAB_RUNNERS.md   §1
# =============================================================================

terraform {
  backend "s3" {
    # Intentionally empty — populated by `-backend-config` in CI.
    # Local development can pass the same flags via:
    #   terraform init -reconfigure -backend-config=.local.s3.tfbackend
  }
}
